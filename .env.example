# No API key required.
# This project uses open-data providers:
# - Nominatim (geocoding/suggestions)
# - Overpass API (nearby places)
# - OSRM (travel time estimates)

# Optional: public site URL used by metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: external backend URL if frontend and API are split
# Example: https://nearby-finder-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=

# Optional: backend tuning
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
CACHE_TTL_MS=120000
